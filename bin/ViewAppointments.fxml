<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="ViewAppointmentsController" prefHeight="450.0" prefWidth="650.0">
    <children>
        <!-- Main Container -->
        <VBox spacing="20.0" alignment="CENTER" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <!-- Title -->
            <Label text="Your Appointments" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1A73E8; -fx-padding: 0 0 10 0;" alignment="CENTER"/>

            <!-- Appointments List -->
            <ListView fx:id="appointmentsListView" prefWidth="610.0" prefHeight="350.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                <placeholder>
                    <Label text="No appointments found." style="-fx-font-size: 16px; -fx-text-fill: #666666; -fx-padding: 20;"/>
                </placeholder>
            </ListView>
        </VBox>
    </children>
</AnchorPane>