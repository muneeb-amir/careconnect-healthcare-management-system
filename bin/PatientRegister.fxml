<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="PatientRegisterController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to bottom, #e6f7ff, #ffffff);">
    <children>
        <VBox alignment="CENTER" spacing="20.0" layoutX="200.0" layoutY="100.0" prefWidth="400.0" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-border-color: #dcdcdc; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="Register as Patient" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                
                <TextField fx:id="nameField" promptText="Full Name" prefWidth="300.0" style="-fx-font-size: 14px;" />
                
                <TextField fx:id="emailField" promptText="Email Address" prefWidth="300.0" style="-fx-font-size: 14px;" />
                
                <PasswordField fx:id="passwordField" promptText="Create Password" prefWidth="300.0" style="-fx-font-size: 14px;" />
                
                <Button text="Register" onAction="#handlePatientRegister" prefWidth="300.0" prefHeight="40.0"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 20;" />
                
                <Hyperlink text="← Back to Login" onAction="#goBack" style="-fx-font-size: 14px; -fx-text-fill: #3498db;" />
            </children>
        </VBox>
    </children>
</AnchorPane>
