<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="LoginController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #e6f7ff;">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <content>
                <VBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20;" prefWidth="600.0">
                    <Label text="CareConnect" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="emailField" promptText="Email" prefWidth="300.0" />
                    <PasswordField fx:id="passwordField" promptText="Password" prefWidth="300.0" />
                    <ComboBox fx:id="roleComboBox" promptText="Login as" prefWidth="300.0" />
                    <Button text="Login" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px;" prefWidth="300.0" />
                    <HBox alignment="CENTER" spacing="20.0">
                        <Hyperlink fx:id="patientRegisterLink" text="Register as Patient" onAction="#goToPatientRegister" style="-fx-font-size: 14px;" />
                        <Hyperlink fx:id="doctorRegisterLink" text="Register as Doctor" onAction="#goToDoctorRegister" style="-fx-font-size: 14px;" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
