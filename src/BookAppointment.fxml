<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="BookAppointmentController" prefHeight="600.0" prefWidth="700.0" style="-fx-background-color: #f0f8ff;">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
            
            <!-- Title -->
            <Label text="Book Appointment" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0078D7;" />

            <!-- Available Doctors -->
            <VBox spacing="10.0" alignment="TOP_LEFT">
                <Label text="Available Doctors:" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <ListView fx:id="doctorListView" prefHeight="180.0" prefWidth="600.0" style="-fx-background-color: white; -fx-border-color: lightgray; -fx-border-radius: 5;" >
                    <placeholder>
                        <Label text="No doctors available."/>
                    </placeholder>
                </ListView>
            </VBox>

            <!-- Date Picker -->
            <VBox spacing="5.0" alignment="TOP_LEFT">
                <Label text="Appointment Date:" style="-fx-font-size: 16px;" />
                <DatePicker fx:id="datePicker" prefWidth="600.0" />
            </VBox>

            <!-- Time Picker -->
            <VBox spacing="5.0" alignment="TOP_LEFT">
                <Label text="Appointment Time:" style="-fx-font-size: 16px;" />
                <ComboBox fx:id="timeComboBox" prefWidth="600.0" promptText="Select time" />
            </VBox>

            <!-- Buttons -->
          <HBox alignment="CENTER" spacing="30.0">
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>
    <Button text="Book Appointment" fx:id="bookButton" onAction="#handleBookAppointment"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 8;"
            prefWidth="250.0" prefHeight="40.0" />
    <Button text="Cancel" fx:id="cancelButton" onAction="#handleCancel"
            style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 8;"
            prefWidth="250.0" prefHeight="40.0" />
</HBox>


        </VBox>
    </children>
</AnchorPane>
