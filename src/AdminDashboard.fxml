<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="AdminDashboardController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #e6f7ff;">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <content>
                <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 20;" prefWidth="600.0">
                    <Label text="Admin Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Label fx:id="welcomeLabel" text="Welcome, Admin!" style="-fx-font-size: 18px; -fx-text-fill: #2c3e50;" />

                    <!-- Patients Section -->
                    <Label text="Patients" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <ListView fx:id="patientsListView" prefWidth="500.0" prefHeight="150.0" />
                    <Button text="Delete Selected Patient" onAction="#deleteSelectedPatient"
                            style="-fx-background-color: #ff6666; -fx-text-fill: white;" prefWidth="250.0" />

                    <!-- Doctors Section -->
                    <Label text="Doctors" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <ListView fx:id="doctorsListView" prefWidth="500.0" prefHeight="150.0" />
                    <Button text="Delete Selected Doctor" onAction="#deleteSelectedDoctor"
                            style="-fx-background-color: #ff6666; -fx-text-fill: white;" prefWidth="250.0" />

                    <!-- Logout -->
                    <Button text="Logout" onAction="#handleLogout"
                            style="-fx-background-color: #ff4444; -fx-text-fill: white; -fx-font-size: 14px;" prefWidth="300.0" />
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
