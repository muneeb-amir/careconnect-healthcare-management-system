<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="ViewDoctorProfilesController" prefHeight="400.0" prefWidth="600.0" stylesheets="app.css">
    <children>
        <!-- Title -->
        <Label text="Doctor Profiles" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0078D7;" alignment="CENTER" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"/>

        <!-- Doctors List -->
        <ListView fx:id="doctorsListView" layoutX="20.0" layoutY="70.0" prefWidth="560.0" prefHeight="300.0">
            <placeholder>
                <Label text="No doctors available."/>
            </placeholder>
        </ListView>
    </children>
</AnchorPane>