<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="AllAppointmentsController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #e6f7ff;">
    <children>
        <Label text="M Appointments" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0078D7;"
               alignment="CENTER" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"/>

        <ListView fx:id="allAppointmentsListView" layoutX="20.0" layoutY="70.0" prefWidth="760.0" prefHeight="400.0">
            <placeholder>
                <Label text="No appointments found." style="-fx-font-size: 14px;"/>
            </placeholder>
        </ListView>

        <Button text="Back" layoutX="20.0" layoutY="530.0" prefWidth="100.0" prefHeight="40.0" onAction="#handleBack"
                style="-fx-background-color: #D9534F; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
    </children>
</AnchorPane>