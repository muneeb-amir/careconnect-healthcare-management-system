<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="DoctorDashboardController" 
            prefWidth="800" prefHeight="600">

    <Label fx:id="welcomeLabel" layoutX="200" layoutY="50"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" 
           text="Doctor Dashboard" />

    <Button fx:id="pendingAppointmentsButton" text="View Pending Requests"
            layoutX="200" layoutY="120" prefWidth="400" prefHeight="50"
            onAction="#handlePendingAppointments"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

    <Button fx:id="allAppointmentsButton" text="View All Appointments"
            layoutX="200" layoutY="190" prefWidth="400" prefHeight="50"
            onAction="#handleAllAppointments"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

    <Button fx:id="updateProfileButton" text="Update Profile"
            layoutX="200" layoutY="260" prefWidth="400" prefHeight="50"
            onAction="#handleUpdateProfile"
            style="-fx-background-color: #0078D7; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

    <Button fx:id="viewEarningsButton" text="View Earnings"
            layoutX="200" layoutY="330" prefWidth="400" prefHeight="50"
            onAction="#handleViewEarnings"
            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

    <Button fx:id="logoutButton" text="Logout"
            layoutX="200" layoutY="400" prefWidth="400" prefHeight="50"
            onAction="#handleLogout"
            style="-fx-background-color: #D9534F; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

</AnchorPane>
