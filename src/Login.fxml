<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="LoginController" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to bottom, #e6f7ff, #ffffff);">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox alignment="CENTER" spacing="25.0" prefWidth="600.0" style="-fx-padding: 50;">
                    <Label text="CareConnect" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Label text="Welcome back! Please log in to continue." style="-fx-font-size: 16px; -fx-text-fill: #34495e;" />
                    
                    <VBox spacing="15.0" alignment="CENTER">
                        <TextField fx:id="emailField" promptText="Email" prefWidth="320.0" style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                        <PasswordField fx:id="passwordField" promptText="Password" prefWidth="320.0" style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                        <ComboBox fx:id="roleComboBox" promptText="Login as" prefWidth="320.0" style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                        <Button text="Login" onAction="#handleLogin" prefWidth="320.0"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8;" />
                    </VBox>
                    
                    <Separator prefWidth="320.0" />
                    
                    <HBox alignment="CENTER" spacing="30.0">
                        <Hyperlink fx:id="patientRegisterLink" text="Register as Patient" onAction="#goToPatientRegister" style="-fx-font-size: 14px;" />
                        <Hyperlink fx:id="doctorRegisterLink" text="Register as Doctor" onAction="#goToDoctorRegister" style="-fx-font-size: 14px;" />
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
