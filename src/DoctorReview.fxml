<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="DoctorReviewController"
      alignment="CENTER" spacing="10" prefWidth="400" prefHeight="300">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Review the Doctor" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <Label text="Select Rating:" />
    <HBox fx:id="starBox" alignment="CENTER" spacing="5" />

    <Label text="Write your review:" />
    <TextArea fx:id="reviewTextArea" prefRowCount="4" prefWidth="300" wrapText="true" />

    <Button text="Submit Review" onAction="#submitReview" />
</VBox>
